# .env.example — plantilla de variables de entorno.
# El .env real (con valores reales) NO se sube (está en .gitignore).
DB_HOST=postgres
DB_PORT=5432
DB_NAME=name
DB_USER=user
DB_PASSWORD=cambiar

POSTGRES_DB=name
POSTGRES_USER=user
POSTGRES_PASSWORD=cambiar

REDIS_HOST=redis
REDIS_PORT=6379
SECRET_KEY=genera_uno_con_secrets_token_hex
SESSION_COOKIE_SECURE=false